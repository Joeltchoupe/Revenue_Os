# ==========================================================
# Revenue OS — Environment Configuration
# Copy to .env and fill in all CHANGE_ME values
# Never commit .env to Git
# ==========================================================

# ─── Core Identity ────────────────────────────────────────
TENANT_ID=CHANGE_ME_tenant_slug
DEFAULT_TENANT_ID=CHANGE_ME_tenant_slug

# ─── n8n ──────────────────────────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_strong_password
N8N_HOST=0.0.0.0
N8N_PORT=5678
WEBHOOK_URL=https://CHANGE_ME.up.railway.app
N8N_TIMEZONE=Africa/Douala
N8N_LOG_LEVEL=info

# ─── Execution Mode ───────────────────────────────────────
# approval = all actions require human sign-off (START HERE)
# auto     = low-risk actions execute without approval
EXECUTION_MODE=approval

# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://CHANGE_ME.supabase.co
SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# ─── Python Service ───────────────────────────────────────
PYTHON_SERVICE_URL=https://CHANGE_ME.up.railway.app
SERVICE_SECRET_KEY=CHANGE_ME_random_32chars

# ─── LLMs ─────────────────────────────────────────────────
# Claude (primary — analysis, generation, reasoning)
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (embeddings + cheap classification)
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL_PRIMARY=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Notifications ────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME
SLACK_CHANNEL_ALERTS=#revos-alerts

# ─── Email Delivery ───────────────────────────────────────
# Choose one: resend (recommended) or gmail
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM_ADDRESS=hello@CHANGE_ME.com
EMAIL_FROM_NAME=Your Name

# Gmail OAuth (if using Gmail instead of Resend)
# GMAIL_CLIENT_ID=CHANGE_ME
# GMAIL_CLIENT_SECRET=CHANGE_ME
# GMAIL_REFRESH_TOKEN=CHANGE_ME
# GMAIL_ACCESS_TOKEN=CHANGE_ME

# ─── CRM ──────────────────────────────────────────────────
# Set CRM_PROVIDER and fill credentials for that provider only
# Options: hubspot | pipedrive | zoho | salesforce
CRM_PROVIDER=hubspot

# HubSpot
HUBSPOT_API_KEY=CHANGE_ME

# Pipedrive
# PIPEDRIVE_API_KEY=CHANGE_ME

# Zoho
# ZOHO_ACCESS_TOKEN=CHANGE_ME
# ZOHO_REGION=com

# Salesforce
# SALESFORCE_INSTANCE_URL=https://CHANGE_ME.salesforce.com
# SALESFORCE_ACCESS_TOKEN=CHANGE_ME

# ─── Bank / Treasury ──────────────────────────────────────
# Options: plaid | stripe | manual
BANK_PROVIDER=plaid

# Plaid
PLAID_CLIENT_ID=CHANGE_ME
PLAID_SECRET=CHANGE_ME
PLAID_ACCESS_TOKEN=CHANGE_ME
# sandbox | development | production
PLAID_ENVIRONMENT=sandbox

# Stripe (if Stripe is primary financial source)
# STRIPE_SECRET_KEY=sk_live_CHANGE_ME

# ─── Lead Enrichment (optional) ───────────────────────────
# If neither configured, system uses email-domain heuristics
CLEARBIT_API_KEY=
APOLLO_API_KEY=

# ─── Tenant Config (defaults — overridden per-tenant in DB) ─
RUNWAY_WARNING_MONTHS=6
RUNWAY_CRITICAL_MONTHS=3
SAFETY_BUFFER_MONTHS=2
MAX_EMAILS_DAY=50
LEAD_HOT_THRESHOLD=80
LEAD_WARM_THRESHOLD=60
CLIENT_CURRENCY=USD

# ─── License ──────────────────────────────────────────────
# Generated by ops/provision_tenant.sh — DO NOT share
LICENSE_TOKEN=CHANGE_ME_license_key_from_provisioning
